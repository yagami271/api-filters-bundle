{
    "name": "isma/api-filters-bundle",
    "description": "Symfony bundle for API filtering",
    "type": "symfony-bundle",
    "license": "MIT",
    "keywords": ["symfony", "bundle", "api", "filter", "query"],
    "require": {
        "php": ">=8.3",
        "symfony/config": "^6.4 || ^7.4 || ^8.0",
        "symfony/dependency-injection": "^6.4 || ^7.4 || ^8.0",
        "symfony/http-foundation": "^6.4 || ^7.4 || ^8.0",
        "symfony/http-kernel": "^6.4 || ^7.4 || ^8.0",
        "doctrine/orm": "^3.4"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^12.0",
        "symfony/browser-kit": "^6.4 || ^7.4 || ^8.0",
        "symfony/var-exporter": "^6.4 || ^7.4 || ^8.0",
        "symfony/framework-bundle": "^6.4 || ^7.4 || ^8.0",
        "symfony/monolog-bundle": "^3.0 || ^4.0",
        "symfony/yaml": "^6.4 || ^7.4 || ^8.0"
    },
    "autoload": {
        "psr-4": {
            "Isma\\ApiFiltersBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Isma\\ApiFiltersBundle\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    }
}

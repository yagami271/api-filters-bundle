{
    "name": "isma/api-filters-bundle",
    "description": "Symfony bundle for API filtering",
    "type": "symfony-bundle",
    "license": "MIT",
    "keywords": ["symfony", "bundle", "api", "filter", "query"],
    "require": {
        "php": ">=8.2",
        "symfony/config": "^7.4",
        "symfony/dependency-injection": "^7.4",
        "symfony/http-foundation": "^7.4",
        "symfony/http-kernel": "^7.4"
    },
    "suggest": {
        "doctrine/orm": "Required for ORM filter strategies (^3.0)"
    },
    "require-dev": {
        "doctrine/orm": "^3.0",
        "friendsofphp/php-cs-fixer": "^3.0",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^12.0",
        "symfony/browser-kit": "^7.4",
        "symfony/framework-bundle": "^7.4",
        "symfony/monolog-bundle": "^3.0",
        "symfony/yaml": "^7.4"
    },
    "autoload": {
        "psr-4": {
            "Isma\\ApiFiltersBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Isma\\ApiFiltersBundle\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
